<%="Promoção de " + @promotion.name%><br>
<%=number_to_percentage @promotion.discount_rate, precision: 2, separator: ',' %><br>
<%=@promotion.code%><br>
<%= I18n.localize @promotion.expiration_date%><br>
<%=@promotion.coupon_quantity%><br>
<%=link_to 'Voltar', promotions_path%>
<%=link_to 'Editar', edit_promotion_path %>
<%=link_to 'Deletar', promotion_path(@promotion),
                        method: :delete,
                        data: { confirm: 'Você tem certeza que deseja deletar essa promoção?'} %>